variable.sh      # 变量实操
#!/bin/bash
# Shell变量实操
# 1. 自定义变量
name="郝少敏"
age=22
echo "姓名：$name，年龄：$age"

# 2. 环境变量
echo "当前用户：$USER"
echo "家目录：$HOME"
echo "系统路径：$PATH"

# 3. 只读变量
readonly job="学生lalalala"
echo "职业：$job"
# job="程序员"  # 会报错，只读变量不可修改

# 4. 删除变量
temp="临时变量"
echo "临时变量：$temp"
unset temp
echo "删除后临时变量：$temp"  # 输出为空
~                                                                               
"variable.sh" 22L, 474C                                       7,0-1         All


param.sh         # 传递参数
#!/bin/bash
# Shell传递参数实操
echo "脚本名：$0"
echo "第1个参数：$1"
echo "第2个参数：$2"
echo "第3个参数：$3"
echo "参数总个数：$#"
echo "所有参数（\$@）：$@"
echo "所有参数（\$*）：$*"
echo "上条命令执行状态：$?"

array.sh         # 数组实操
#!/bin/bash
# Shell数组实操
# 1. 定义数组
fruits=("苹果" "香蕉" "橙子" "葡萄")
nums=(1 2 3 4 5)

# 2. 读取数组元素
echo "第一个水果：${fruits[0]}"
echo "所有水果：${fruits[@]}"

# 3. 获取数组长度
echo "水果数组长度：${#fruits[@]}"
echo "数字数组长度：${#nums[@]}"

# 4. 遍历数组
echo "遍历水果数组："
for fruit in ${fruits[@]}
do
    echo "$fruit"
done
~                                                                               
~                                                                               
~                                                                               
"array.sh" 20L, 417C                                          20,1          All


print.sh         # echo/printf
#!/bin/bash
# echo/printf实操
# 1. echo命令
echo "Hello, Shell!"
echo -e "换行\n测试\t制表符"  # -e 开启转义
echo "当前用户：$USER"

# 2. printf命令
printf "%-10s %-8s %-4s\n" 姓名 年龄 职业
printf "%-10s %-8s %-4s\n" 郝少敏 24 学生
printf "%-10s %-8s %-4s\n" 张三 25 程序员
~                                                



